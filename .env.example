# =============================================================================
# Real-Time Events Analytics Pipeline - Environment Variables (TEMPLATE)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# These variables are interpolated into config.yaml via config_loader.py and
# are also read directly by docker-compose.
#
#   cp .env.example .env
# =============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_ENV=local                       # local | dev | staging | prod
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# ----------------------------------------------------------------------------
# Kafka / Schema Registry
# ----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ----------------------------------------------------------------------------
# Apache Spark
# ----------------------------------------------------------------------------
SPARK_MASTER=local[*]
CHECKPOINT_DIR=./checkpoints

# ----------------------------------------------------------------------------
# Google Cloud Platform / BigQuery
# ----------------------------------------------------------------------------
# Create a service account with roles: BigQuery Data Editor, BigQuery Job User,
# and Storage Object Admin (for the temp bucket). Download the JSON key to
# ./config/gcp-key.json (git-ignored).
GCP_PROJECT_ID=my-gcp-project
BQ_DATASET=rtep_analytics
BQ_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=./config/gcp-key.json
BQ_TEMP_BUCKET=rtep-spark-temp

# ----------------------------------------------------------------------------
# Alerting (optional)
# ----------------------------------------------------------------------------
# Slack/Teams incoming webhook for pipeline alerts. Leave blank to log only.
ALERT_WEBHOOK_URL=
